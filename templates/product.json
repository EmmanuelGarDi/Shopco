    "shopco_product_tabs": {
      "type": "shopco-product-tabs",
      "settings": {
        "tab_details_label": "Product Details",
        "tab_reviews_label": "Rating & Reviews",
        "tab_faqs_label": "FAQs",
        "fallback_details": "<p>This graphic t-shirt is perfect for any occasion. Crafted from a soft and breathable fabric, it offers superior comfort and style.</p>",
        "review_count": 451,
        "reviews_visible": 4
      },
      "blocks": {
        "review_1": {
          "type": "review",
          "settings": {
            "author": "Samantha D.",
            "rating": 5,
            "text": "I absolutely love this t-shirt! The design is unique and the fabric feels so comfortable. As a fellow designer, I appreciate the attention to detail. It's become my favorite go-to shirt.",
            "date": "August 14, 2023",
            "verified": true
          }
        },
        "review_2": {
          "type": "review",
          "settings": {
            "author": "Alex M.",
            "rating": 4,
            "text": "The t-shirt exceeded my expectations! The colors are vibrant and the print quality is top-notch. I'm a graphic designer, and I can appreciate the attention to detail.",
            "date": "August 15, 2023",
            "verified": true
          }
        },
        "review_3": {
          "type": "review",
          "settings": {
            "author": "Ethan R.",
            "rating": 5,
            "text": "This t-shirt is a must-have for anyone who appreciates good design. The minimalist yet stylish pattern caught my eye, and the fit is perfect.",
            "date": "August 16, 2023",
            "verified": true
          }
        },
        "review_4": {
          "type": "review",
          "settings": {
            "author": "Olivia P.",
            "rating": 5,
            "text": "As a UI/UX enthusiast, I value simplicity and functionality. This t-shirt not only represents those principles but also feels great to wear.",
            "date": "August 17, 2023",
            "verified": true
          }
        },
        "review_5": {
          "type": "review",
          "settings": {
            "author": "Liam K.",
            "rating": 5,
            "text": "Excellent quality and fast shipping. The fabric is soft and the fit is true to size. Highly recommend!",
            "date": "August 18, 2023",
            "verified": true
          }
        },
        "review_6": {
          "type": "review",
          "settings": {
            "author": "Ava S.",
            "rating": 4,
            "text": "Great shirt overall. The color is exactly as shown and the material is breathable. Would buy again.",
            "date": "August 19, 2023",
            "verified": true
          }
        },
        "faq_1": {
          "type": "faq",
          "settings": {
            "question": "What is the return policy?",
            "answer": "We offer a 30-day return policy for unworn items with tags attached. Contact our support team to initiate a return."
          }
        },
        "faq_2": {
          "type": "faq",
          "settings": {
            "question": "How do I care for this product?",
            "answer": "Machine wash cold with like colors. Tumble dry low. Do not bleach or iron directly on the print."
          }
        },
        "faq_3": {
          "type": "faq",
          "settings": {
            "question": "What sizes are available?",
            "answer": "This product is available in Small, Medium, Large, and X-Large. Refer to our size guide for measurements."
          }
        }
      },
